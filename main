import psutil
import os
import colorama
import time
from colorama import Fore, Back, Style, init
os.system('cls' if os.name == 'nt' else 'clear')

while True:
    cpu=psutil.cpu_percent(interval=1)
    ram=psutil.virtual_memory().percent
    os.system('cls' if os.name == 'nt' else 'clear')

    print(Fore.RED+Style.BRIGHT+"ANSM "+Style.RESET_ALL+Style.BRIGHT+"Panel\n")

    if cpu<50:
        print(Style.BRIGHT +  "CPU usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.GREEN + f" {cpu} " + Style.RESET_ALL)
    elif cpu<80:
        print(Style.BRIGHT+"CPU usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.YELLOW + f" {cpu} " + Style.RESET_ALL)
    elif cpu>=85:
        print(Style.BRIGHT +"CPU usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.RED + f" {cpu} " + Style.RESET_ALL)
    elif cpu>=95:
        print(Style.BRIGHT +"CPU usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.RED + f" {cpu} ! ! !" + Style.RESET_ALL)

    if ram<50:
        print(Style.BRIGHT +  "RAM usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.GREEN + f" {ram} " + Style.RESET_ALL)
    elif ram<80:
        print(Style.BRIGHT+"RAM usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.YELLOW + f" {ram} " + Style.RESET_ALL)
    elif ram<90:
        print(Style.BRIGHT +"RAM usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.RED + f" {ram} " + Style.RESET_ALL)
    elif ram>=95:
        print(Style.BRIGHT +"RAM usage: " + Style.RESET_ALL + Style.BRIGHT + Fore.RED + f" {ram} ! ! !" + Style.RESET_ALL)

    print("\nmade by ary")
    continue